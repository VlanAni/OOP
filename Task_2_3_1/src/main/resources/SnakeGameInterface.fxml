<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.sun.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ru.vladimirdev.snake.managers.MenuController"
      alignment="CENTER"
      prefWidth="320"
      style="-fx-background-color: #1a1a2e;">

    <padding>
        <Insets top="48" right="48" bottom="48" left="48"/>
    </padding>

    <Label text="SNAKE"
           style="-fx-text-fill: #00b894;
                  -fx-font-size: 48px;
                  -fx-font-weight: bold;
                  -fx-font-family: 'Segoe UI', 'SF Pro Display', sans-serif;">
    </Label>

    <Label text="Choose difficulty level"
           style="-fx-text-fill: #636e72;
                  -fx-font-size: 12px;
                  -fx-font-family: 'Segoe UI', sans-serif;
                  -fx-padding: 4 0 0 0;">
    </Label>

    <VBox spacing="12" alignment="CENTER"
          style="-fx-padding: 36 0 0 0;">

        <Button text="Easy"
                maxWidth="Infinity"
                onAction="#onEasy"
                style="-fx-background-color: #00b894;
                       -fx-text-fill: #1a1a2e;
                       -fx-font-size: 15px;
                       -fx-font-weight: bold;
                       -fx-font-family: 'Segoe UI', sans-serif;
                       -fx-padding: 14 0 14 0;
                       -fx-background-radius: 10;
                       -fx-cursor: hand;">
        </Button>

        <Button text="Medium"
                maxWidth="Infinity"
                onAction="#onMedium"
                style="-fx-background-color: #fdcb6e;
                       -fx-text-fill: #1a1a2e;
                       -fx-font-size: 15px;
                       -fx-font-weight: bold;
                       -fx-font-family: 'Segoe UI', sans-serif;
                       -fx-padding: 14 0 14 0;
                       -fx-background-radius: 10;
                       -fx-cursor: hand;">
        </Button>

        <Button text="Hard"
                maxWidth="Infinity"
                onAction="#onHard"
                style="-fx-background-color: #e17055;
                       -fx-text-fill: #ffffff;
                       -fx-font-size: 15px;
                       -fx-font-weight: bold;
                       -fx-font-family: 'Segoe UI', sans-serif;
                       -fx-padding: 14 0 14 0;
                       -fx-background-radius: 10;
                       -fx-cursor: hand;">
        </Button>
    </VBox>


    <Separator style="-fx-padding: 28 0 20 0; -fx-background-color: #1a1a2e;"/>


    <Button text="Quit"
            onAction="#onQuit"
            style="-fx-background-color: transparent;
                   -fx-text-fill: #636e72;
                   -fx-border-color: #636e72;
                   -fx-border-width: 1;
                   -fx-border-radius: 8;
                   -fx-background-radius: 8;
                   -fx-font-size: 13px;
                   -fx-font-family: 'Segoe UI', sans-serif;
                   -fx-padding: 9 24 9 24;
                   -fx-cursor: hand;">
    </Button>

</VBox>
